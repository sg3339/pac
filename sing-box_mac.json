{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-bootstrap",
        "address": "8.8.8.8",
        "detour": "direct"
      },
      {
        "tag": "dns-google",
        "address": "https://dns.google/dns-query",
        "address_resolver": "dns-bootstrap",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "dns.google"
        ],
        "server": "dns-bootstrap"
      }
    ],
    "final": "dns-google",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": "172.19.0.1/30",
      "mtu": 1500,
      "auto_route": true,
      "strict_route": true,
      "stack": "gvisor",
      "sniff": true,
      "sniff_override_destination": true,
      "endpoint_independent_nat": true
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "http",
      "tag": "opera",
      "server": "192.168.0.30",
      "server_port": 18080
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rules": [
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": "proxied-domains",
        "network": "udp",
        "port": 443,
        "action": "reject"
      },
      {
        "rule_set": "proxied-domains",
        "outbound": "opera"
      }
    ],
    "rule_set": [
      {
        "tag": "proxied-domains",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/sg3339/pac/refs/heads/main/domains_all.srs"
      }
    ],
    "final": "direct"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db"
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": ""
    }
  }
}
