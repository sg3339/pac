function FindProxyForURL(url, host) {
    var lhost = host.toLowerCase();

    // Убираем порт, если есть
    var colon = lhost.indexOf(":");
    if (colon !== -1) { lhost = lhost.substring(0, colon); }

    // Прямая проверка — YouTube/googlevideo → SOCKS5
    if (youtubeDomains[lhost]) { return SOCKS5; }

    // Проверка родительских доменов — YouTube/googlevideo
    var parts = lhost.split(".");
    for (var i = 1; i < parts.length - 1; i++) {
        var parent = parts.slice(i).join(".");
        if (youtubeDomains[parent]) { return SOCKS5; }
    }

    // Прямая проверка — основные заблокированные → HTTP прокси
    if (blockedDomains[lhost]) { return PROXY; }

    // Проверка родительских доменов — основные
    for (var j = 1; j < parts.length - 1; j++) {
        var p = parts.slice(j).join(".");
        if (blockedDomains[p]) { return PROXY; }
    }

    return DIRECT;
}
