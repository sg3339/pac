function FindProxyForURL(url, host) {
    var lhost = host.toLowerCase();
    var colon = lhost.indexOf(":");
    if (colon !== -1) { lhost = lhost.substring(0, colon); }

    var d = lhost;
    while (d.length > 0) {
        if (youtubeDomains[d]) { return SOCKS5; }
        if (blockedDomains[d]) { return PROXY; }
        var dot = d.indexOf(".");
        if (dot === -1) break;
        d = d.substring(dot + 1);
    }

    return DIRECT;
}
