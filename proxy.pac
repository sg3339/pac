function FindProxyForURL(url, host) {
    var lhost = host.toLowerCase();
    var colon = lhost.indexOf(":");
    if (colon !== -1) { lhost = lhost.substring(0, colon); }
    var parts = lhost.split(".");

    if (youtubeDomains[lhost]) { return SOCKS5; }
    for (var i = 1; i < parts.length - 1; i++) {
        if (youtubeDomains[parts.slice(i).join(".")]) { return SOCKS5; }
    }

    if (blockedDomains[lhost]) { return PROXY; }
    for (var j = 1; j < parts.length - 1; j++) {
        if (blockedDomains[parts.slice(j).join(".")]) { return PROXY; }
    }

    return DIRECT;
}
