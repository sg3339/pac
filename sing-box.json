{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-bootstrap-google",
        "address": "8.8.8.8",
        "detour": "direct"
      },
      {
        "tag": "dns-bootstrap-cloudflare",
        "address": "1.1.1.1",
        "detour": "direct"
      },
      {
        "tag": "dns-google",
        "address": "https://dns.google/dns-query",
        "address_resolver": "dns-bootstrap-cloudflare",
        "detour": "opera"
      },
      {
        "tag": "dns-cloudflare",
        "address": "https://cloudflare-dns.com/dns-query",
        "address_resolver": "dns-bootstrap-google",
        "detour": "opera"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "dns.google",
          "google.com"
        ],
        "server": "dns-bootstrap-cloudflare"
      },
      {
        "domain_suffix": [
          "cloudflare-dns.com",
          "cloudflare.com"
        ],
        "server": "dns-bootstrap-google"
      }
    ],
    "final": "dns-google",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "utun0",
      "address": "172.19.0.1/30",
      "mtu": 1420,
      "auto_route": true,
      "strict_route": false,
      "endpoint_independent_nat": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "socks",
      "tag": "byedpi",
      "server": "192.168.0.30",
      "server_port": 1080
    },
    {
      "type": "socks",
      "tag": "opera",
      "server": "192.168.0.30",
      "server_port": 1081
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "resolve",
        "strategy": "ipv4_only"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "network": "udp",
        "port": 443,
        "rule_set": [
          "refilter_domains",
          "refilter_ipsum"
        ],
        "action": "reject"
      },
      {
        "network": "udp",
        "port": 443,
        "domain_suffix": [
          "eden-emu.dev",
          "2ip.ru"
        ],
        "action": "reject"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "youtube.com",
          "youtu.be",
          "googlevideo.com",
          "ytimg.com",
          "ggpht.com",
          "wide-youtube.l.google.com",
          "youtube-nocookie.com",
          "youtube-ui.l.google.com",
          "youtube.googleapis.com",
          "youtubeembeddedplayer.googleapis.com",
          "youtubei.googleapis.com",
          "youtubekids.com",
          "yt.be",
          "withyoutube.com",
          "youtubeeducation.com",
          "youtubefanfest.com",
          "youtubegaming.com",
          "youtubego.com",
          "youtubemobilesupport.com",
          "yt3.googleusercontent.com"
        ],
        "outbound": "byedpi"
      },
      {
        "domain_suffix": [
          "eden-emu.dev",
          "2ip.ru"
        ],
        "outbound": "opera"
      },
      {
        "rule_set": [
          "refilter_domains",
          "refilter_ipsum"
        ],
        "outbound": "opera"
      }
    ],
    "rule_set": [
      {
        "tag": "refilter_domains",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/1andrevich/Re-filter-lists/releases/latest/download/ruleset-domain-refilter_domains.srs",
        "download_detour": "direct"
      },
      {
        "tag": "refilter_ipsum",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/1andrevich/Re-filter-lists/releases/latest/download/ruleset-ip-refilter_ipsum.srs",
        "download_detour": "direct"
      }
    ],
    "final": "direct",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db"
    }
  }
}
