{
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",

      "inet4_address": "172.19.0.1/30",

      "auto_route": true,
      "strict_route": true,

      "sniff": true,
      "sniff_override_destination": false
    }
  ],

  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },

    {
      "type": "http",
      "tag": "opera",
      "server": "192.168.0.30",
      "server_port": 18080
    }
  ],

  "route": {
    "auto_detect_interface": true,

    "rules": [
      {
        "domain_suffix": [
          "2ip.ru"
        ],
        "outbound": "opera"
      }
    ],

    "final": "direct"
  }
}
