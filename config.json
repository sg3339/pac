{
  "log": {
    "level": "info"
  },

  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "inet4_address": "172.19.0.1/30",
      "auto_route": true,
      "strict_route": true
    }
  ],

  "outbounds": [
    {
      "type": "http",
      "tag": "proxy",
      "server": "192.168.0.30",
      "server_port": 18080
    },

    {
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "rules": [
      {
        "domain_suffix": [
          "instagram.com",
          "cdninstagram.com",
          "fbcdn.net",
          "tiktok.com",
          "tiktokv.com",
          "byteoversea.com",
          "ibyteimg.com",
          "muscdn.com"
        ],
        "outbound": "proxy"
      }
    ],

    "final": "direct"
  }
}